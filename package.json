{
  "name": "@pi-vault/pi-tools",
  "version": "0.3.0",
  "type": "module",
  "description": "Pi extension for web search, page fetching, documentation lookup, and deep research",
  "author": "Lanh Hoang <lanhhoang@users.noreply.github.com>",
  "license": "MIT",
  "homepage": "https://github.com/pi-vault/pi-tools#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pi-vault/pi-tools.git"
  },
  "bugs": {
    "url": "https://github.com/pi-vault/pi-tools/issues"
  },
  "keywords": [
    "pi",
    "pi-coding-agent",
    "pi-package",
    "pi-extension",
    "pi-tools",
    "code-search",
    "web-fetch",
    "web-search",
    "web-docs",
    "web-research"
  ],
  "scripts": {
    "format": "biome format --write .",
    "lint": "biome lint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "check": "biome lint . && tsc --noEmit && vitest run",
    "pack:dry-run": "pnpm pack --dry-run",
    "release:check": "pnpm check && pnpm run pack:dry-run"
  },
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "engines": {
    "node": ">=24.15.0"
  },
  "files": [
    "src",
    "docs/assets",
    "LICENSE",
    "CHANGELOG.md",
    "README.md"
  ],
  "dependencies": {
    "@joplin/turndown-plugin-gfm": "^1.0.67",
    "@mozilla/readability": "^0.6.0",
    "linkedom": "^0.18.13",
    "turndown": "^7.2.4",
    "unpdf": "^1.6.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "@earendil-works/pi-ai": "^0.80.6",
    "@earendil-works/pi-coding-agent": "^0.80.6",
    "@earendil-works/pi-tui": "^0.80.6",
    "@types/node": "^26.1.1",
    "@types/turndown": "^5.0.6",
    "typebox": "^1.3.6",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*"
  },
  "peerDependenciesMeta": {
    "@earendil-works/pi-ai": { "optional": true },
    "@earendil-works/pi-coding-agent": { "optional": true },
    "@earendil-works/pi-tui": { "optional": true }
  }
}
