{
  "name": "@pi-vault/pi-tools",
  "version": "0.2.0",
  "type": "module",
  "description": "Pi extension for quick access to code search, web fetch, and web search tools",
  "author": "Lanh Hoang <lanhhoang@users.noreply.github.com>",
  "license": "MIT",
  "homepage": "https://github.com/pi-vault/pi-tools#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pi-vault/pi-tools.git"
  },
  "bugs": {
    "url": "https://github.com/pi-vault/pi-tools/issues"
  },
  "keywords": [
    "pi",
    "pi-coding-agent",
    "pi-package",
    "pi-extension",
    "pi-tools",
    "code-search",
    "web-fetch",
    "web-search"
  ],
  "scripts": {
    "format": "biome format --write .",
    "lint": "biome lint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "check": "biome lint . && tsc --noEmit && vitest run",
    "pack:dry-run": "pnpm pack --dry-run",
    "release:check": "pnpm check && pnpm run pack:dry-run"
  },
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "engines": {
    "node": ">=24.15.0"
  },
  "files": [
    "src",
    "docs/assets",
    "LICENSE",
    "CHANGELOG.md",
    "README.md"
  ],
  "dependencies": {
    "@joplin/turndown-plugin-gfm": "^1.0.67",
    "@mozilla/readability": "^0.6.0",
    "linkedom": "^0.18.12",
    "turndown": "^7.2.4",
    "unpdf": "^1.6.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@earendil-works/pi-coding-agent": "^0.80.2",
    "@earendil-works/pi-tui": "^0.80.2",
    "@types/node": "^26.0.1",
    "@types/turndown": "^5.0.6",
    "typebox": "^1.3.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*"
  }
}
